{
    "dependencies": {},
    "devDependencies": {
        "@types/bun": "^1.2.19",
        "cspell": "^9.2.0",
        "dprint": "^0.50.1",
        "lefthook": "^1.12.2",
        "markdownlint-cli2": "^0.18.1"
    },
    "markdownlint-cli2": {
        "config": {
            "MD010": {
                "code_blocks": false,
                "spaces_per_tab": 4
            },
            "MD013": false,
            "MD024": {
                "siblings_only": true
            }
        }
    },
    "cspell": {
        "version": "0.2",
        "ignorePaths": [
            "*.lock",
            ".*",
            "blender-pasty.code-workspace",
            "dictionaries",
            "package.json",
            "pyproject.toml"
        ],
        "languageSettings": [
            {
                "languageId": "markdown",
                "words": []
            },
            {
                "languageId": "shellscript",
                "words": [],
                "dictionaryDefinitions": [
                    {
                        "name": "bash-extended",
                        "path": "./dictionaries/bash-extended.txt"
                    }
                ],
                "dictionaries": [
                    "bash-extended"
                ]
            },
            {
                "languageId": "python",
                "words": [],
                "dictionaryDefinitions": [
                    {
                        "name": "python-extended",
                        "path": "./dictionaries/python-extended.txt"
                    }
                ],
                "dictionaries": [
                    "python-extended"
                ]
            }
        ],
        "overrides": [
            {
                "filename": "script/*",
                "languageId": "shellscript",
                "dictionaries": [
                    "shellscript"
                ],
                "allowCompoundWords": true
            },
            {
                "filename": "script/extension",
                "languageId": "python"
            },
            {
                "filename": "script/fix-whitespace",
                "languageId": "typescript"
            }
        ],
        "words": [
            "bunx",
            "dprint",
            "pycache",
            "thanhph111"
        ],
        "ignoreWords": [],
        "import": [],
        "language": "en-US",
        "enableFiletypes": []
    }
}
