#!/usr/bin/env -S uv run -s


def main():
    import shutil
    import subprocess
    import sys

    # Check if blender executable exists in PATH
    blender_path = shutil.which("blender")

    if blender_path:
        # If blender exists, call it directly with `--command` extension
        try:
            cmd = [blender_path, "--command", "extension", *sys.argv[1:]]
            result = subprocess.run(cmd, check=True)
            sys.exit(result.returncode)
        except subprocess.CalledProcessError as e:
            print(f"Blender command failed: {e}", file=sys.stderr)
            sys.exit(e.returncode)
        except Exception as e:
            print(f"An error occurred while running blender: {e}", file=sys.stderr)
            sys.exit(1)
    else:
        # Fall back to the approach using `bl_pkg`
        try:
            # Trigger internal modules import, this is official `bpy`, not `fake-bpy-module` package
            import bpy  # noqa: F401 (unused import)

            # Suppress `PGH003` use `type: ignore` comments which suppresses both ty and Pyright
            from bl_pkg.bl_extension_cli import (  # type: ignore  # noqa: PGH003
                cli_extension_handler,
            )

            # Run the extension CLI, equivalent to `blender --command extension`
            cli_extension_handler(sys.argv[1:])
        except ImportError as e:
            print(f"Blender not found and bpy/bl_pkg modules not available: {e}", file=sys.stderr)
            print(
                "Please install Blender or ensure the required Python packages are available.",
                file=sys.stderr,
            )
            sys.exit(1)
        except Exception as e:
            print(f"An error occurred: {e}", file=sys.stderr)
            sys.exit(1)


if __name__ == "__main__":
    main()
