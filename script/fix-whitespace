#!/usr/bin/env bun

async function processFile(filepath) {
    try {
        const file = Bun.file(filepath);
        const text = await file.text();

        // Fix trailing whitespace and ensure single newline at EOF
        const lines = text.split("\n");
        const processedLines = lines.map(line => line.trimEnd());

        // Remove empty lines at the end while keeping one newline
        while (processedLines.length > 0 && processedLines[processedLines.length - 1] === "") {
            processedLines.pop();
        }
        processedLines.push("");

        const processedText = processedLines.join("\n");

        // Only write and show message if content changed
        if (processedText !== text) {
            try {
                await Bun.write(filepath, processedText);
                console.log(`✓ Fixed ${filepath}`);
                return true;
            } catch (writeError) {
                console.error(`✗ Failed to write to ${filepath}:`, writeError);
                return false;
            }
        }
        return false;
    } catch (error) {
        console.error(`✗ Error processing ${filepath}:`, error);
        return false;
    }
}

async function main() {
    const files = process.argv.slice(2);

    if (files.length === 0) {
        console.error("Please provide at least one file path");
        process.exit(1);
    }

    console.log(`Processing ${files.length} files...`);

    // Process all files in parallel and collect results
    const results = await Promise.all(files.map(processFile));

    console.log("Done!");

    // Exit with code 1 if any file was modified
    const hasChanges = results.some(changed => changed);
    process.exit(hasChanges ? 1 : 0);
}

main().catch(error => {
    console.error(error);
    process.exit(1);
});
