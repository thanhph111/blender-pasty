#!/usr/bin/env bash

# [MISE] description="Run all linters and formatters"

set -euo pipefail

files=()
while IFS= read -r -d '' file; do
    if [[ -e "$file" ]]; then
        files+=("$file")
    fi
done < <(git ls-files -z --cached --others --exclude-standard)

if [[ "${#files[@]}" -eq 0 ]]; then
    exit 0
fi

prek --files "${files[@]}"
